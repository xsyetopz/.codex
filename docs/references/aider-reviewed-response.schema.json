{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "contract": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "satisfied"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "contract",
          "status",
          "evidence"
        ],
        "additionalProperties": false
      }
    },
    "final": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "verification",
    "final"
  ],
  "additionalProperties": false
}
