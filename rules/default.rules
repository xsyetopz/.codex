# Dependency manifests and local lockfiles are normal development edits.
for manager in ["npm", "pnpm", "bun"]:
    for action in ["install", "add", "remove", "uninstall", "update", "link", "unlink"]:
        allow([manager, action], "Project dependency and lockfile updates are approved.")
    prompt([manager, "publish"], "Publishing to a package registry requires current user approval.")
for manager in ["npm", "pnpm", "bun"]:
    prompt([manager, ["install", "add"], ["-g", "--global"]], "Global package installation requires current user approval.")
prompt(["npm", "deprecate"], "Changing published package metadata requires current user approval.")
prompt(["pnpm", "deploy"], "Creating a deployment bundle requires current user approval.")
for action in ["add", "remove", "install", "uninstall", "update", "publish", "yank"]:
    prompt(["cargo", action], "Dependency, toolchain, or registry mutation requires current user approval.")
prompt(["go", "get"], "Changing Go module dependencies requires current user approval.")
prompt(["go", "install"], "Installing a Go binary requires current user approval.")
prompt(["python3", "-m", "pip", ["install", "uninstall"]], "Python environment mutation requires current user approval.")
prompt(["pip", ["install", "uninstall"]], "Python environment mutation requires current user approval.")
prompt(["pip3", ["install", "uninstall"]], "Python environment mutation requires current user approval.")
prompt(["uv", ["add", "remove", "sync", "publish"]], "Dependency, environment, or registry mutation requires current user approval.")
prompt(["uv", "pip", ["install", "uninstall"]], "Python environment mutation requires current user approval.")
prompt(["poetry", ["add", "remove", "install", "update", "publish"]], "Dependency, environment, or registry mutation requires current user approval.")
prompt(["gem", ["install", "uninstall", "push", "yank"]], "Ruby environment or registry mutation requires current user approval.")
prompt(["dotnet", ["add", "remove"], "package"], ".NET dependency mutation requires current user approval.")
prompt(["dotnet", "tool", ["install", "uninstall", "update"]], ".NET toolchain mutation requires current user approval.")
prompt(["dotnet", "nuget", ["push", "delete"]], "NuGet registry mutation requires current user approval.")
allow(["brew", ["info", "list", "search", "outdated"]], "Homebrew inspection is approved.")
prompt(["brew", ["install", "uninstall", "upgrade", "update", "tap", "untap", "services"]], "System package or service mutation requires current user approval.")

# Git inspection, normal history creation, and fast-forward publication are approved.
# Destructive recovery, forced publication, and deletion forms remain guarded.
allow(["git"], "Git inspection, staging, fetching, and working-tree edits are approved. Specific prompt rules below take precedence.")
for action in ["commit", "merge", "rebase", "cherry-pick", "revert", "am"]:
    allow(["git", action], "Normal local Git history creation is approved.")
allow(["git", "push"], "Normal Git ref publication is approved; force and deletion forms prompt below.")
allow(["git", "tag"], "Normal Git tag creation is approved; replacement and deletion forms prompt below.")
prompt(["git", "commit", "--amend"], "Amending published or shared history requires current user approval.")
for flag in ["--force", "-f", "--force-with-lease", "--force-if-includes", "--delete", "-d"]:
    prompt(["git", "push", flag], "Forced or deleting Git publication requires current user approval.")
    for remote in ["origin", "upstream"]:
        prompt(["git", "push", remote, flag], "Forced or deleting Git publication requires current user approval.")
for flag in ["--force", "-f", "--delete", "-d"]:
    prompt(["git", "tag", flag], "Replacing or deleting a Git tag requires current user approval.")
for action in ["reset", "restore", "checkout", "switch", "notes", "replace", "update-ref"]:
    prompt(["git", action], "This Git operation can replace working-tree or ref state and requires current user approval.")
prompt(["git", "clean"], "Deleting untracked files requires current user approval.")
prompt(["git", "config"], "Changing Git configuration or identity requires current user approval.")
prompt(["git", "branch", ["-d", "-D", "-m", "-M"]], "Deleting or renaming a branch requires current user approval.")
prompt(["git", "remote", ["add", "remove", "rename", "set-url", "prune", "update"]], "Changing Git remotes requires current user approval.")
prompt(["git", "stash", ["push", "pop", "apply", "drop", "clear", "branch"]], "Changing stashed or working-tree state requires current user approval.")
prompt(["git", "worktree", ["add", "remove", "move", "prune", "repair", "lock", "unlock"]], "Changing worktree state requires current user approval.")
prompt(["git", "submodule", ["add", "update", "deinit", "set-url", "set-branch"]], "Changing submodule state requires current user approval.")
prompt(["git", ["gc", "prune"]], "Pruning Git objects requires current user approval.")
prompt(["git", "reflog", "expire"], "Expiring reflog recovery data requires current user approval.")
prompt(["git", "lfs", ["push", "lock", "unlock", "prune"]], "Publishing or deleting Git LFS state requires current user approval.")

# GitHub reads are approved; remote writes prompt.
allow(["gh"], "GitHub inspection is approved. Specific prompt rules below take precedence.")
allow(["gh", "api"], "Read-only GitHub API inspection is approved. Explicit write and upload forms prompt below.")
for flag in ["-X", "--method", "-f", "--raw-field", "-F", "--field", "--input"]:
    prompt(["gh", "api", flag], "GitHub API writes, uploads, or request bodies require current user approval.")
prompt(["gh", "pr", ["create", "merge", "close", "reopen", "edit", "review", "comment", "ready"]], "Changing pull-request state requires current user approval.")
prompt(["gh", "issue", ["create", "close", "reopen", "edit", "comment", "delete"]], "Changing issue state requires current user approval.")
allow(["gh", "release", ["create", "upload", "edit"]], "Creating and updating GitHub releases is approved.")
prompt(["gh", "release", ["delete", "delete-asset"]], "Deleting GitHub releases or assets requires current user approval.")
prompt(["gh", "repo", ["create", "delete", "fork", "archive", "rename", "edit"]], "Changing repository state requires current user approval.")
allow(["gh", "workflow", "run"], "Dispatching an existing GitHub workflow is approved.")
prompt(["gh", "workflow", ["enable", "disable"]], "Changing workflow availability requires current user approval.")
allow(["gh", "run", ["rerun", "cancel"]], "Rerunning or cancelling a GitHub workflow is approved.")
prompt(["gh", "run", "delete"], "Deleting workflow-run history requires current user approval.")
prompt(["gh", "secret"], "Changing or reading repository secrets requires current user approval.")
prompt(["gh", "variable"], "Changing repository variables requires current user approval.")
allow(["gh", "auth", "status"], "Read-only GitHub authentication status inspection is approved.")
for action in ["login", "logout", "refresh", "setup-git", "switch"]:
    prompt(["gh", "auth", action], "Changing GitHub authentication requires current user approval.")
prompt(["gh", "auth", "token"], "Reading an authentication token can expose a credential; current user approval is required.")
prompt(["gh", "cache", "delete"], "Deleting GitHub Actions caches requires current user approval.")
prompt(["gh", "gist", ["create", "edit", "delete"]], "Changing gist state requires current user approval.")
prompt(["gh", "label", ["create", "edit", "delete", "clone"]], "Changing label state requires current user approval.")
prompt(["gh", "project"], "Changing GitHub project state requires current user approval.")
prompt(["gh", "codespace", ["create", "delete", "rebuild", "stop", "ssh"]], "Changing or entering a codespace requires current user approval.")

# Network reads and diagnostics. Known write forms prompt.
allow(["curl"], "HTTP verification is approved. Explicit write-form rules below take precedence.")
prompt(["curl", ["-X", "--request"]], "An explicit HTTP method requires current user approval.")
prompt(["curl", ["-d", "--data", "--data-raw", "--data-binary", "-F", "--form", "-T", "--upload-file"]], "Uploading HTTP request data requires current user approval.")
allow(["wget"], "HTTP download verification is approved. Explicit write-form rules below take precedence.")
prompt(["wget", ["--post-data", "--post-file", "--method", "--body-data", "--body-file"]], "An HTTP write request requires current user approval.")
allow(["dig"], "DNS diagnostics are approved.")
allow(["nslookup"], "DNS diagnostics are approved.")
allow(["ping"], "Network reachability diagnostics are approved.")
prompt(["ssh"], "Remote shell access requires current user approval.")
prompt(["scp"], "Remote file transfer requires current user approval.")
prompt(["sftp"], "Remote file transfer requires current user approval.")

