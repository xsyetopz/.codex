# ~/.codex/rules/default.rules
# The strictest matching decision wins: forbidden > prompt > allow.

def rule(pattern, decision, why, match = [], not_match = []):
    prefix_rule(
        pattern = pattern,
        decision = decision,
        justification = why,
        match = match,
        not_match = not_match,
    )

def allow(pattern, why = "Routine local command is approved.", match = [], not_match = []):
    rule(pattern, "allow", why, match, not_match)

def prompt(pattern, why, match = [], not_match = []):
    rule(pattern, "prompt", why, match, not_match)

def forbid(pattern, why, match = [], not_match = []):
    rule(pattern, "forbidden", why, match, not_match)

# Read-only discovery and inspection.
allow(["rg"], "Repository text search is approved.", match = ["rg TODO src"], not_match = ["grep TODO src"])
allow(["fd"], "Repository path search is approved.")
allow(["find"], "Filesystem path search is approved.")
allow(["ls"], "Directory inspection is approved.")
allow(["pwd"], "Working-directory inspection is approved.")
allow(["cat"], "File inspection is approved.")
allow(["head"], "File inspection is approved.")
allow(["tail"], "File inspection is approved.")
allow(["jq"], "Structured JSON inspection is approved.")
allow(["sed", "-n"], "Non-mutating line inspection is approved.")
allow(["wc"], "File and stream counting is approved.")
allow(["sort"], "Stream sorting is approved.")
allow(["uniq"], "Stream deduplication is approved.")
allow(["cut"], "Stream field selection is approved.")
allow(["tr"], "Stream character translation is approved.")
allow(["diff"], "File comparison is approved.")
allow(["cmp"], "Binary comparison is approved.")
allow(["file"], "File-type inspection is approved.")
allow(["stat"], "Filesystem metadata inspection is approved.")
allow(["du"], "Disk-usage inspection is approved.")
allow(["df"], "Filesystem-capacity inspection is approved.")
allow(["shasum"], "Checksum calculation is approved.")
allow(["md5"], "Checksum calculation is approved.")
allow(["date"], "Clock inspection is approved.")
allow(["uname"], "Platform inspection is approved.")
allow(["whoami"], "Current-user inspection is approved.")
allow(["id"], "Identity inspection is approved.")
allow(["which"], "Executable lookup is approved.")
allow(["ps"], "Process inspection is approved.")
allow(["pgrep"], "Process lookup is approved.")
allow(["lsof"], "Open-file and port inspection is approved.")
allow(["printf"], "Direct stdout formatting is approved.")
allow(["echo"], "Direct stdout formatting is approved.")

# In-scope local file creation. Destructive or relocating operations prompt below.
allow(["cp"], "In-scope local file copying is approved.")
allow(["mkdir"], "In-scope local directory creation is approved.")
allow(["touch"], "In-scope local file creation is approved.")
prompt(["mv"], "Moving or overwriting a path requires current user approval.")
prompt(["rm"], "Deleting a path requires current user approval.")
prompt(["rmdir"], "Deleting a directory requires current user approval.")
prompt(["ln"], "Creating a link can cross trust boundaries; current user approval is required.")
prompt(["truncate"], "Truncating a file destroys content; current user approval is required.")
prompt(["rsync"], "Rsync can overwrite local or remote paths; current user approval is required.")
prompt(["chmod"], "Changing file permissions requires current user approval.")
prompt(["chown"], "Changing file ownership requires current user approval.")
prompt(["xattr"], "Changing extended attributes requires current user approval.")
prompt(["dd"], "Raw block copying can destroy data; current user approval is required.")

forbid(
    ["rm", ["-rf", "-fr"], "/"],
    "Root deletion is blocked. Delete a named workspace path instead.",
    match = ["rm -rf /", "rm -fr /"],
    not_match = ["rm -rf ./build"],
)
forbid(
    ["rm", "-rf", "--no-preserve-root", "/"],
    "Root deletion is blocked. Delete a named workspace path instead.",
)
forbid(
    ["sudo", "rm", ["-rf", "-fr"], "/"],
    "Privileged root deletion is blocked. Delete a named workspace path instead.",
)
forbid(
    ["chmod", "-R", "777", "/"],
    "Recursive world-writable root permissions are blocked. Change a named workspace path instead.",
)
forbid(["mkfs"], "Filesystem formatting is blocked. Use a disposable image or sandbox instead.")

