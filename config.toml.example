#:schema https://developers.openai.com/codex/config-schema.json

model_catalog_json = "~/.codex/skizzles/model-catalog.json"

approval_policy = "on-request"
approvals_reviewer = "auto_review"
allow_login_shell = false

model = "gpt-5.6-sol"
review_model = "gpt-5.6-sol"
model_reasoning_effort = "medium"
model_reasoning_summary = "concise"
model_verbosity = "low"
model_instructions_file = "~/.codex/instructions/skizzles-base.md"
developer_instructions = """
Operate exclusively on software, hardware, systems engineering, technical research, architecture, implementation, debugging, review, verification, and directly supporting technical discussion. If a request is outside this scope, decline it briefly and do not continue it.

Treat the interaction as an operator-agent engineering session. Make no unsupported claims about either participant, including identity, internal state, preferences, or capabilities. Avoid rapport-building, praise, reassurance, motivational framing, roleplay, and small talk. Use a neutral engineering register.

Prefer observable facts, primary sources, reproducible results, explicit requirements, and measurable acceptance criteria. Distinguish confirmed facts, user decisions, proposals, inferences, uncertainties, preferences, and engineering judgments. When multiple valid solutions exist, select by stated criteria and describe material tradeoffs.

Own the requested technical outcome within granted authority. Preserve unrelated work and constraints. Diagnose before changing, implement at the owning boundary, validate causally, and report evidence plus remaining uncertainty. Do not substitute discussion for executable work when an authorized change is requested.

Injected Skizzles and Fourth Wall guidance is authoritative for delegation, model routing, task graphs, roles, handoffs, and subagent lifecycle. Do not duplicate, weaken, or replace that runtime policy.
"""
compact_prompt = """
Create a compact continuation checkpoint for another engineering agent resuming the same task.

Preserve only:
- the technical objective, acceptance criteria, explicit scope, constraints, and non-goals;
- confirmed decisions and their evidence or rationale;
- exact relevant files, configuration keys, interfaces, commands, tests, and runtime state;
- changes completed, unrelated work that must be preserved, receipts, rollback data, and source provenance;
- active Goal state, task graph, ownership, routing decisions, dependencies, blockers, authority boundaries, and the next executable action;
- material failures and whether they are product, environment, permission, or validation failures;
- distinctions among confirmed facts, user decisions, proposals, inferences, uncertainties, preferences, and engineering judgments.

Discard repetition, conversational padding, superseded exploration, completed dead ends, raw logs already summarized, and unsupported speculation. Never convert an unverified claim into a fact, a proposal into a decision, a partial check into a pass, or prior context into new authority. Use concise sections or bullets with exact paths and contract tokens.
"""
personality = "none"
plan_mode_reasoning_effort = "medium"
service_tier = "flex"
web_search = "live"

project_doc_max_bytes = 12288
tool_output_token_limit = 8000

default_permissions = ":danger-full-access"
cli_auth_credentials_store = "keyring"
analytics.enabled = false
hide_agent_reasoning = true
file_opener = "cursor"
disable_paste_burst = true

[permissions.project-edit]
description = "Edit workspace roots, deny secret files, and allow network access."
extends = ":workspace"

[permissions.project-edit.filesystem.":workspace_roots"]
"**/.env" = "deny"
"**/.env.*" = "deny"
".codex" = "read"
".devcontainer" = "read"

[permissions.project-edit.network]
enabled = true

[agents]
max_depth = 1
interrupt_message = false

[features]
fast_mode = false
image_generation = false
prevent_idle_sleep = true
personality = false
in_app_browser = false
computer_use = false
apps = false
secret_auth_storage = false
workspace_dependencies = true

[features.multi_agent_v2]
max_concurrent_threads_per_session = 7
tool_namespace = "team"
hide_spawn_agent_metadata = false
enabled = true
multi_agent_mode_hint_text = "Proactive complexity-aware delegation is active. Follow $fourth-wall whenever orchestration would materially improve speed or quality."
root_agent_usage_hint_text = "Fourth Wall applies. Read and follow $fourth-wall before this task's first orchestration action."
subagent_usage_hint_text = "Fourth Wall applies. Read and follow $fourth-wall and the behavioral role resource named in your assignment."

[plugins."openai-developers@openai-curated"]
enabled = true

[plugins."skizzles@skizzles"]
enabled = true

[tui]
status_line = [
    "model-with-reasoning",
    "context-remaining",
    "five-hour-limit",
    "weekly-limit",
    "used-tokens",
]
notifications = ["agent-turn-complete", "approval-requested"]
notification_condition = "unfocused"
notification_method = "auto"
animations = false
show_tooltips = false
terminal_title = ["spinner", "project", "model"]

[shell_environment_policy]
inherit = "core"
ignore_default_excludes = false
experimental_use_profile = false
exclude = [
    "*_TOKEN",
    "*_SECRET",
    "*_KEY",
    "*_PASSWORD",
    "*_CREDENTIALS",
    "*_API_KEY",
    "*_AUTH*",
    "*_CLIENT*",
    "*_BEARER*",
    "*_SIGNATURE*",
    "*_HASH*",
    "*_SALT*",
    "*_PRIVATE*",
    "*_CERT*",
]
set = { CODEX_HOME = "~/.codex", PATH = "~/.local/bin:~/.bun/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin" }

[mcp_servers.openaiDeveloperDocs]
url = "https://developers.openai.com/mcp"

[mcp_servers.CodeGraphContext]
command = "~/.local/bin/cgc"
args = ["mcp", "start"]
enabled = true
startup_timeout_sec = 30
tool_timeout_sec = 120

enabled_tools = [
    "add_code_to_graph",
    "add_package_to_graph",
    "check_job_status",
    "list_jobs",
    "find_code",
    "analyze_code_relationships",
    "watch_directory",
    "find_dead_code",
    "execute_cypher_query",
    "calculate_cyclomatic_complexity",
    "find_most_complex_functions",
    "list_indexed_repositories",
    "delete_repository",
    "list_watched_paths",
    "unwatch_directory",
    "visualize_graph_query",
]
default_tools_approval_mode = "approve"

[mcp_servers.CodeGraphContext.env]
CGC_ALLOWED_ROOTS = "~/CodeProjects"
DEFAULT_DATABASE = "falkordb"
FALKORDB_PATH = "~/.codegraphcontext/global/db/falkordb"
FALKORDB_SOCKET_PATH = "~/.codegraphcontext/global/db/falkordb.sock"
LADYBUGDB_PATH = "~/.codegraphcontext/global/db/ladybugdb"
KUZUDB_PATH = "~/.codegraphcontext/global/db/kuzudb"
INDEX_VARIABLES = "true"
ALLOW_DB_DELETION = "false"
DEBUG_LOGS = "false"
DEBUG_LOG_PATH = "~/mcp_debug.log"
ENABLE_APP_LOGS = "CRITICAL"
LIBRARY_LOG_LEVEL = "WARNING"
LOG_FILE_PATH = "~/.codegraphcontext/logs/cgc.log"
MAX_FILE_SIZE_MB = "10"
IGNORE_TEST_FILES = "false"
IGNORE_HIDDEN_FILES = "true"
ENABLE_AUTO_WATCH = "false"
COMPLEXITY_THRESHOLD = "10"
MAX_DEPTH = "unlimited"
PARALLEL_WORKERS = "4"
CACHE_ENABLED = "true"
IGNORE_DIRS = "node_modules,venv,.venv,env,.env,dist,build,target,out,.git,.idea,.vscode,__pycache__"
INDEX_SOURCE = "true"
SCIP_INDEXER = "false"
SCIP_LANGUAGES = "python,typescript,javascript,go,rust,java,dart,cpp,c,csharp"
SKIP_EXTERNAL_RESOLUTION = "false"
MAX_TOOL_RESPONSE_TOKENS = "0"
TOOL_RESULT_LIMITS = "{}"
ENABLE_INHERIT_RESOLVE = "false"
ENABLE_VECTOR_RESOLVE = "false"
CGC_EMBEDDING_MODEL = "local"
CGC_EMBEDDING_BATCH_SIZE = "256"
FUZZY_SEARCH = "true"

[notice]
hide_rate_limit_model_nudge = true

[notice.model_migrations]
"gpt-5.5" = "gpt-5.6-sol"
"gpt-5.4" = "gpt-5.6-sol"
"gpt-5.4-mini" = "gpt-5.6-terra"
"gpt-5.3-codex-spark" = "gpt-5.6-luna"

[history]
persistence = "save-all"
max_bytes = 268435456

[tools]
web_search = { context_size = "high" }

[hooks.state]

[marketplaces.skizzles]
last_updated = "2026-07-17T20:20:30Z"
last_revision = "870f21f50d86a4d7c8df8b6c5c46932b2c673c08"
source_type = "git"
source = "https://github.com/robertmsale/skizzles.git"
ref = "870f21f50d86a4d7c8df8b6c5c46932b2c673c08"
