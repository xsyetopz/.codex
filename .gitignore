!/hooks/
!/hooks/**
!/agents/
!/agents/**

# Durable knowledge, policy, validation, and role sources
!/docs/
!/docs/**
!/rules/
!/rules/**
!/scripts/
!/scripts/**

# Generated documentation is runtime output.
/docs/generated/

# Never publish credentials, conversations, rollouts, databases, or host state.
/.caveman.json
/config.toml
/*.config.toml
!/build.config.toml
!/deep.config.toml
!/speed.config.toml
!/promptlab.config.toml
/auth.json
/history.jsonl
/installation_id
/attachments/
/cache/
/log/
